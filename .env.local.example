# Notion integration token — create one at https://www.notion.so/my-integrations
# then share your habits database with the integration
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The ID of your Notion habits database — copy it from the database URL:
# https://www.notion.so/<workspace>/<DATABASE_ID>?v=...
NOTION_DB_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
